generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int              @id @default(autoincrement())
  mobile            String           @unique
  createdAt         DateTime         @default(now())
  email             String?
  isProfileComplete Boolean          @default(false)
  name              String?
  area              String?
  city              String?
  latitude          Float?
  locality          String?
  longitude         Float?
  Apartment         Apartment[]
  Commercial        Commercial[]
  Flatmate          Flatmate[]
  likes             Like[]
  receivedMessages  Message[]        @relation("Receiver")
  sentMessages      Message[]        @relation("Sender")
  properties        PGDetails[]
  subscriptions     Subscription[]
  UserPreference    UserPreference[]
  visits            Visit[]
}

model Subscription {
  id           Int      @id @default(autoincrement())
  userId       Int
  planType     String
  planDuration String
  amount       Int
  paymentId    String
  propertyType String
  startDate    DateTime
  expiryDate   DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Otp {
  id        Int      @id @default(autoincrement())
  mobile    String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UserPreference {
  id              Int      @id @default(autoincrement())
  userId          Int
  city            String?
  locality        String?
  search          String?
  pgFor           String?
  sharingTypes    Json?
  preferredTenant String?
  availability    String?
  parking         String?
  foodIncluded    Boolean?
  rentMin         Int?
  rentMax         Int?
  amenities       Json?
  nearby          Json?
  restrictions    Json?
  premiumSort     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model Like {
  id         Int        @id @default(autoincrement())
  userId     Int
  propertyId Int?
  createdAt  DateTime   @default(now())
  flatmateId Int?
  flatmate   Flatmate?  @relation(fields: [flatmateId], references: [id])
  property   PGDetails? @relation(fields: [propertyId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([userId, propertyId])
  @@unique([userId, flatmateId])
}

model Visit {
  id            Int         @id @default(autoincrement())
  date          String?
  time          String?
  propertyType  String?
  language      String      @default("en")
  userId        Int
  propertyId    Int
  createdAt     DateTime    @default(now())
  isCalled      Boolean     @default(false)
  visitDateTime DateTime?
  status        VisitStatus @default(pending)
  property      PGDetails   @relation(fields: [propertyId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([propertyId])
  @@index([status])
}



model PGDetails {
  id                  Int            @id @default(autoincrement())
  userId              Int
  city                String
  locality            String
  street              String?
  landmark            String?
  latitude            Float?
  longitude           Float?
  propertyName        String?
  propertyType        String
  roomType            Json?
  foodIncluded        Boolean?
  foodType            Json?
  pgAmenities         Json?
  parking             String?
  propertyType2       String?
  availableFrom       DateTime?
  noticePeriod        Int?
  gateClosingTime     DateTime?
  images              String[]       @default([])
  video               String?
  contactName         String?
  mobileNo            String?
  whatsapp            Boolean?
  whatsappupdates     Boolean?
  preferredTenant     Json?
  preferredGuests     Json?
  restrictions        Json?
  propertyDescription String?

  availableAllDay          Boolean?
  endTime                  String?
  startTime                String?
  availabilityDay         Json?

  viewscount          Int       @default(0)
  currentStep         Int            @default(1)
  isDraft             Boolean        @default(true)
  isDeleted           Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  likes               Like[]
  messages            Message[]      @relation("PropertyMessages")
  user                User           @relation(fields: [userId], references: [id])
  visits              Visit[]
  @@map("Property") 
}


model Commercial {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  city                    String
  locality                String?
  street                  String?
  landmark                String?
  latitude                Float?
  longitude               Float?
  propertyType            String?
  buildingType            String?
  propertyAge             String?
  floor                   Int?
  totalFloor              Int?
  builtUpArea             Int?
  furnishing              Json?
  otherFeatures           Json?
  rentType                String?
  expectedRent            Int?
  deposit                 Int?
  maintenanceAmount       Int?
  maintenance             String?
  rentNegotiable          Boolean?
  depositNegotiable       Boolean?
  maintenanceExtra        Boolean?
  leaseDuration           String?
  lockinPeriod            String?
  availableFrom           String?
  idealFor                Json?
  addOthertags            String?
  contactName             String?
  mobileNo                String?
  whatsapp                Boolean?
  images                  String[]
  video                   String?
  description             String?
  availabilityDay         Json?
 viewscount              Int      @default(0)
  startTime               String?
  endTime                 String?
  availableAllDay         Boolean?
  currentStep             Int      @default(1)
  isDraft                 Boolean  @default(true)
  createdAt               DateTime @default(now())
  commercialPropertyType  String?
  commercialOtherFeatures Json?
  slots                   String?
  user                    User     @relation(fields: [userId], references: [id])
}



model Message {
  id         Int       @id @default(autoincrement())
  senderId   Int
  receiverId Int
  propertyId Int
  message    String
  createdAt  DateTime  @default(now())
  property   PGDetails @relation("PropertyMessages", fields: [propertyId], references: [id])
  receiver   User      @relation("Receiver", fields: [receiverId], references: [id])
  sender     User      @relation("Sender", fields: [senderId], references: [id])

  @@index([propertyId])
  @@index([senderId])
  @@index([receiverId])
}

model Flatmate {
  id                   Int       @id @default(autoincrement())
  userId               Int
  city                 String
  propertyType         String
  apartmentType        String?
  apartmentName        String?
  bhkType              String?
  floor                String?
  totalFloor           String?
  roomType             String?
  tenantType           String?
  propertyAge          String?
  facing               String?
  builtUpArea          Float?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  landmark             String?
  latitude             Float?
  locality             String?
  longitude            Float?
  street               String?
  availableFrom        DateTime?
  description          String?
  expectedDeposit      Float?
  expectedRent         Float?
  furnishing           String?
  maintenanceAmount    Float?
  maintenanceType      String?
  parking              String?
  acRoom               Boolean?
  attachedBathroom     Boolean?
  balcony              Boolean?
  bathroomType         String?
  clubHouseSelected    Boolean?  @default(false)
  directionsTip        String?
  drinkingAllowed      Boolean?
  gatedSecurity        Boolean?
  gym                  Boolean?
  liftSelected         Boolean?  @default(false)
  nonVegAllowed        Boolean?
  parkSelected         Boolean?  @default(false)
  powerBackupSelected  Boolean?  @default(false)
  secondaryNumber      String?
  smokingAllowed       Boolean?
  swimmingPoolSelected Boolean?  @default(false)
  waterSupply          String?
  whoShowsProperty     String?
  availabilityDay      Json?
  availableAllDay      Boolean?
  endTime              String?
  images               String[]  @default([])
  viewscount           Int       @default(0)
  startTime            String?
  video                String?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Like                 Like[]
  
}

model Apartment {
  id                       Int      @id @default(autoincrement())
  userId                   Int
  city                     String
  locality                 String
  street                   String?
  landmark                 String?
  latitude                 Float?
  longitude                Float?
  buildingType             String?
  bhkType                  String?
  floor                    Int?
  totalFloor               Int?
  builtUpArea              Int?
  propertyAge              String?
  facing                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  propertyType2            String?
  otherFeatures            Json?
  furnishing               String?
  rentType                 String?
  apartmentType            String?
  availableFrom            String?
  description              String?
  maintenance              String?
  parking                  String?
  rentNegotiable           Boolean?
  expectedRent             Int?
  deposit                  Int?
  maintenanceAmount        Int?
  preferredTenant          String[]
  amenities                String[]
  bathroom                 Int?
  directions               String?
  gateSecurity             Boolean?
  gymAllowed               Boolean?
  noOfBalcony              Int?
  nonVegAllowed            Boolean?
  petAllowed               Boolean?
  propertyCondition        Json?
  secondaryNumber          String?
  shownBy                  String?
  unitsPropertiesAvailable Boolean?
  waterSupply              Json?
  availabilityDay          Json?
  images                   String[] @default([])
  viewscount               Int       @default(0)
  video                    String?
  availableAllDay          Boolean?
  endTime                  String?
  startTime                String?
  user                     User     @relation(fields: [userId], references: [id])
}

enum VisitStatus {
  pending
  confirmed
  calling
  cancelled
  completed
}
